{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "afurgeri/laravel-crud",
    "description": "Declarative CRUD definitions and managers for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/pagination": "^13.0",
        "illuminate/process": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/validation": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Crud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Crud\\CrudServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest --compact",
        "lint": "pint --test --format agent"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
